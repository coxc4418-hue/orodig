# API (Render / local)
PORT=8080
NODE_ENV=development
SESSION_SECRET=change-me-in-production
LOG_LEVEL=info

# Firebase — server (Render). JSON string of service account key (recommended in production)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=oro-dig
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=

# Frontend build (Firebase Hosting)
VITE_API_URL=https://orodig.onrender.com

# Optional — Drizzle schema push only (not runtime)
DATABASE_URL=postgresql://user:pass@localhost:5432/orodig
